{
    "name": "Andlet",
    "short_name": "Andlet",
    "description": "Your trusted property network for verified rentals and inspections",
    "start_url": "/",
    "scope": "/",
    "display": "standalone",
    "background_color": "#ffffff",
    "theme_color": "#2B9C64",
    "orientation": "portrait",
    "display_override": [
        "window-controls-overlay"
    ],
    "categories": [
        "real estate",
        "property",
        "rental",
        "lifestyle"
    ],
    "lang": "en",
    "dir": "ltr",
    "prefer_related_applications": false,
    "handle_links": "preferred",
    "shortcuts": [
        {
            "name": "Search Properties",
            "short_name": "Search",
            "description": "Start searching for properties",
            "url": "/listings",
            "icons": [
                {
                    "src": "/search-icon.png",
                    "sizes": "96x96"
                }
            ]
        },
        {
            "name": "My Dashboard",
            "short_name": "Dashboard",
            "url": "/dashboard",
            "icons": [
                {
                    "src": "/dashboard-icon.png",
                    "sizes": "96x96"
                }
            ]
        }
    ],
    "icons": [
        {
            "src": "/logo.svg",
            "sizes": "any",
            "type": "image/svg+xml",
            "purpose": "any"
        },
        {
            "src": "/logo.svg",
            "sizes": "any",
            "type": "image/svg+xml",
            "purpose": "maskable"
        },
        {
            "src": "/192x192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "/512x512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any"
        }
    ],
    "screenshots": [
        {
            "src": "/screenshots/home.jpg",
            "sizes": "1080x1920",
            "type": "image/jpeg",
            "form_factor": "narrow",
            "label": "Home screen with property listings"
        },
        {
            "src": "/screenshots/dashboard.jpg",
            "sizes": "1080x1920",
            "type": "image/jpeg",
            "form_factor": "narrow",
            "label": "Agent dashboard"
        }
    ]
}